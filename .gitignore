# Ignore everything
*

# Except the following:
#
# Go exports
!core
!core/*.go
!models
!models/*.go
!db
!db/*.go

# Files in root
!main.go
!Dockerfile
!go.*
!.gitignore
!docker-compose.yml
!entrypoint.sh
!line-numbers.patch
!main.go.embedded
!Makefile

# Public assets
!public
!public/*.html
!public/heroicons.svg
!public/plugin.js
!public/highlightjs
!public/highlightjs/v11.11.1
!public/highlightjs/v11.11.1/*
!public/marked
!public/marked/v18.0.7
!public/marked/v18.0.7/*
!public/dompurify
!public/dompurify/v3.4.12
!public/dompurify/v3.4.12/*


# Node modules
!frameworks
!frameworks/*js*

# Github workflows
!.github/
!.github/workflows/
!.github/workflows/*.yml

# Deployment guide
!deployment/
!deployment/*.md
